{
  "name": "@music163/ncm-cli",
  "version": "0.1.3",
  "description": "Netease Music CLI tool - supporting music playback, search, and playlist management",
  "main": "dist/index.js",
  "bin": {
    "ncm-cli": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build.js prod",
    "build:test": "node scripts/build.js test",
    "build:mlbclaw": "node scripts/build.js mlbclaw",
    "build:prod": "node scripts/build.js prod",
    "build:types": "tsc --emitDeclarationOnly --declaration --outDir dist",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "publish:test": "npm run build:test && npm publish --tag beta",
    "publish:mlbclaw": "npm run build:mlbclaw && npm publish --tag mlbclaw",
    "publish:prod": "npm run build:prod && npm publish",
    "pack:mlbclaw": "node scripts/pack-release.js mlbclaw",
    "pack:prod": "node scripts/pack-release.js prod",
    "pack:mlbclaw:no-zip": "node scripts/pack-release.js mlbclaw --no-zip",
    "pack:prod:no-zip": "node scripts/pack-release.js prod --no-zip",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:login": "npx ts-node tests/manual-login-test.ts"
  },
  "keywords": [
    "netease",
    "music",
    "cli",
    "player",
    "playback"
  ],
  "author": "Netease Music",
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^1.1.0",
    "build": "^0.1.4",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "image-size": "^1.1.1",
    "json-bigint": "^1.0.0",
    "node-fetch": "^3.3.2",
    "qrcode-terminal": "^0.12.0",
    "run": "^1.5.0",
    "semver": "^7.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/jest": "^29.5.0",
    "@types/json-bigint": "^1.0.4",
    "@types/node": "^20.19.39",
    "@types/semver": "^7.0.0",
    "esbuild": "^0.27.3",
    "glob": "^13.0.6",
    "javascript-obfuscator": "^5.3.0",
    "jest": "^29.7.0",
    "qrcode": "^1.5.4",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
